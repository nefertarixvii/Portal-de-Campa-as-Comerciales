@model List<PortalCampanas.Models.Campania>

<h2>Listado de Campañas</h2>
<form method="get" asp-action="Index" style="margin-bottom:20px;">
    <label>Categoría:</label>
    <input type="text" name="categoria" value="@ViewData["categoria"]" />

    <label>Estado:</label>
    <input type="text" name="estado" value="@ViewData["estado"]" />

    <button type="submit">Filtrar</button>
    <a href="/Campanas/Index">Limpiar</a>
    <a href="/Campanas/Resumen" style="margin-bottom:10px; display:inline-block;">
    Ver resumen de campañas
    </a>
</form>
<table border="1">
    <tr>
        <th>Nombre</th>
        <th>Categoría</th>
        <th>Estado</th>
        <th>Canal</th>
        <th>Descuento</th>
        <th>Acción</th>
    </tr>

@foreach (var c in Model)
{
    <tr>
        <td>@c.Nombre</td>
        <td>@c.Categoria</td>
        <td>@c.Estado</td>
        <td>@c.Canal</td>
        <td>@c.DescuentoPct %</td>
        <td>
            <a href="/Campanas/Detalle/@c.Id">Ver detalle</a>
        </td>
    </tr>
}
</table>